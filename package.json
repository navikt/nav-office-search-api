    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/node-schedule": "2.1.8",
    "dotenv": "17.4.2",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
