{
  "compilerOptions": {
    "allowJs": true,
    "rootDir": "src",
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": [
      "esnext",
      "dom",
    ],
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "outDir": "./distSrc",
    "strict": true,
    "target": "es2022",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
  ]
}
